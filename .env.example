# Copy this file to .env (local) or paste into your cloud platform's env-vars panel
# PORT is set automatically by Railway/Render/Azure — leave blank on those platforms

# --- Required for cloud deployment ---
REQUIRE_AUTH=true

# --- Change these before deploying ---
FACTORY_USER=factory.lead
FACTORY_PASS=AMS@Pilot2026

# --- Set this to your platform's persistent volume path ---
# Railway:       DB_PATH=/data/factory.db
# Render:        DB_PATH=/opt/render/project/src/factory.db
# Azure App Svc: DB_PATH=/home/factory.db
# Local:         DB_PATH=   (leave blank — uses ./factory.db by default)
DB_PATH=
